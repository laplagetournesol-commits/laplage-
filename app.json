{
  "expo": {
    "name": "Les Tournesols",
    "slug": "laplagetournesols",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tournesol",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lestournesols.app",
      "buildNumber": "13"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDF8F0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.lestournesols.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-video",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.lestournesols.app",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1964dce-195f-4bc5-962b-b8eddce420d2"
      }
    },
    "owner": "laplagetournesols"
  }
}
